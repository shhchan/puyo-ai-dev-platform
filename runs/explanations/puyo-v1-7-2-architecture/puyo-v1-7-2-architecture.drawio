<mxfile host="Electron" modified="2026-07-16T01:29:41.621Z" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/24.4.13 Chrome/124.0.6367.207 Electron/30.0.6 Safari/537.36" etag="Sgo1o5nnQxu2aCf_4fyG" version="24.4.13" type="device" pages="3">
  <diagram id="v172-runtime-architecture" name="1. 現行Runtimeアーキテクチャ">
    <mxGraphModel dx="2795" dy="1597" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="1" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="WD4-vwN35DC2D8uVpPbx-1" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="50" y="60" width="2540" height="1850" as="geometry" />
        </mxCell>
        <mxCell id="tKkHR2rGfIARAxmE2a8m-1" value="" style="group" parent="WD4-vwN35DC2D8uVpPbx-1" vertex="1" connectable="0">
          <mxGeometry width="2540" height="1680" as="geometry" />
        </mxCell>
        <mxCell id="a-registry" value="TacticSpec Registry v1.7.2（戦術定義台帳）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;build_main / prepare_response&lt;br&gt;counter_or_return / pressure&lt;br&gt;lethal_attack / all_clear&lt;br&gt;fire_main / survive&lt;br&gt;&lt;br&gt;各戦術の適用条件 + 目標 + 制約&lt;br&gt;beam 探索予算 + fallback 先を定義&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7e6;strokeColor=#b7791f;strokeWidth=2;fontColor=#623b00;fontSize=13;fontStyle=1;spacing=9;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="980" y="670" width="320" height="280" as="geometry" />
        </mxCell>
        <mxCell id="a-title" value="v1.7.2 現行 Runtime アーキテクチャ — 学習済み Manager と探索 Worker のハイブリッド構成" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=25;fontStyle=1;fontColor=#172033;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="440" width="1890" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a-input" value="1. Runtime 観測&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;自分 / 相手の盤面&lt;br&gt;現在の組ぷよ + 見えている NEXT&lt;br&gt;予告おじゃま + 到着期限&lt;br&gt;持越し得点 / 全消しの状態遷移&lt;br&gt;直前 \(N\) ターンの計画&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5f2;strokeColor=#0f766e;strokeWidth=2;fontColor=#143f3b;fontSize=14;fontStyle=1;spacing=10;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="120" y="170" width="290" height="240" as="geometry" />
        </mxCell>
        <mxCell id="a-analyzer" value="2. StateAnalyzer（局面解析器）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;生盤面を構造化した診断値へ変換&lt;br&gt;危険度 / 脆弱性&lt;br&gt;本線連鎖の見込み&lt;br&gt;攻撃候補 / おじゃま到着時間帯&lt;br&gt;BuildPotential v2（連鎖構築可能性の指標）&lt;br&gt;発火点の復旧可能性&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf2ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#193763;fontSize=14;fontStyle=1;spacing=10;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="580" y="170" width="300" height="240" as="geometry" />
        </mxCell>
        <mxCell id="a-features" value="3. Feature Contract（特徴量契約）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;生の盤面セルは直接入力しない&lt;br&gt;局面特徴ベクトル&lt;br&gt;戦術別特徴行列&lt;br&gt;適用可否マスク&lt;br&gt;直前計画の特徴量&lt;br&gt;schema&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-weight: normal; background-color: initial;&quot;&gt;で形状 / 順序を検証&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4f46e5;strokeWidth=2;fontColor=#312e81;fontSize=14;fontStyle=1;spacing=10;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="970" y="170" width="300" height="240" as="geometry" />
        </mxCell>
        <mxCell id="a-manager" value="4. Learned Tactic Manager（学習済み戦術選択器）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;共有 MLP encoder（特徴抽出器）&lt;br&gt;8 戦術それぞれの出力 head&lt;br&gt;提案 logit / 価値 / リスク&lt;br&gt;目標 + 探索 parameter&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;上位3戦術の候補一覧&lt;br&gt;preview 結果を加味した最終選択&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7e22ce;strokeWidth=3;fontColor=#442260;fontSize=14;fontStyle=1;spacing=10;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="1580" y="140" width="370" height="300" as="geometry" />
        </mxCell>
        <mxCell id="a-preview" value="5. Tactic Preview Loop（戦術の事前探索）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;適用可能な上位 3 戦術までを preview&lt;br&gt;戦術ごとに PlannerRequest を生成&lt;br&gt;各 preview で Worker 探索を 1 回実行&lt;br&gt;連鎖 / 攻撃 / リスク / コストを特徴量化&lt;br&gt;Manager が最終戦術を選択&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7e6;strokeColor=#b7791f;strokeWidth=2;fontColor=#623b00;fontSize=14;fontStyle=1;spacing=10;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="2130" y="140" width="340" height="300" as="geometry" />
        </mxCell>
        <mxCell id="a-checkpoint" value="現在の Checkpoint（学習済み重み）の実態&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;policy_type: v1_7_bootstrap_manager&lt;br&gt;v1.7.1の初期重みを移行&lt;br&gt;教師ありで戦術 / parameter を学習&lt;br&gt;v1.7.2 schema 互換性を追加&lt;br&gt;&lt;br&gt;混合対戦相手による RL は未実施&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e5;strokeColor=#d97706;strokeWidth=3;fontColor=#7c2d12;fontSize=14;fontStyle=1;spacing=10;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="820" y="440" width="580" height="200" as="geometry" />
        </mxCell>
        <mxCell id="a-worker" value="6. StrategyOrchestrator + Worker（探索の振分けと実行器）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;構築 → diverse beam Worker&lt;br&gt;対応準備 → response Worker&lt;br&gt;その他の戦術 → tactical Worker&lt;br&gt;BuildPotential v2 で評価&lt;br&gt;depth / width / probe / latency 予算&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#feecef;strokeColor=#be123c;strokeWidth=2;fontColor=#67142b;fontSize=14;fontStyle=1;spacing=10;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="2080" y="570" width="430" height="270" as="geometry" />
        </mxCell>
        <mxCell id="a-batch" value="7. WorkerProposalBatch v1（探索候補の固定形式データ）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;固定 \(K\) slot + 候補 mask&lt;br&gt;安定した candidate / proposal ID&lt;br&gt;初手 action + action 列&lt;br&gt;連鎖 / 攻撃 / BuildPotential&lt;br&gt;発火 / 復旧可能性 / 危険度&lt;br&gt;latency + 展開 node 数&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#0891b2;strokeWidth=3;fontColor=#164e63;fontSize=14;fontStyle=1;spacing=10;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="2090" y="910" width="400" height="300" as="geometry" />
        </mxCell>
        <mxCell id="a-compat" value="8. 現行の候補選択&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;compatibility_action()（互換選択関数）&lt;br&gt;常に候補 slot 0 を採用&lt;br&gt;従来 heuristic の並び順を維持&lt;br&gt;&lt;br&gt;CandidateRanker は未学習&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;strokeWidth=3;fontColor=#7f1d1d;fontSize=14;fontStyle=1;spacing=10;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="2130" y="1320" width="330" height="260" as="geometry" />
        </mxCell>
        <mxCell id="a-artifacts" value="Replay / Rollout / Gate成果物（検証記録）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;戦術診断 + PlannerRequest&lt;br&gt;K-best 候補群 + mask + telemetry&lt;br&gt;seed / config / commit / schema / latency&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;strokeWidth=2;fontColor=#334155;fontSize=13;fontStyle=1;spacing=9;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="1550" y="995" width="360" height="130" as="geometry" />
        </mxCell>
        <mxCell id="a-future" value="PUYO-130 で実装予定 — 現在は未実装&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;CandidateRanker（候補順位付け器）の policy head&lt;br&gt;mask 適用済み候補分布&lt;br&gt;critic（価値評価器）/ 価値目標&lt;br&gt;結合 log 確率 + entropy&lt;br&gt;混合対戦相手の報酬による更新&lt;br&gt;選択候補と最良候補の regret 学習&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;strokeWidth=3;dashed=1;fontColor=#14532d;fontSize=14;fontStyle=1;spacing=10;" parent="tKkHR2rGfIARAxmE2a8m-1" vertex="1">
          <mxGeometry x="1640" y="1310" width="370" height="260" as="geometry" />
        </mxCell>
        <mxCell id="a-e1" value="確定した局面状態" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;fontColor=#334155;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-input" target="a-analyzer" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-e2" value="診断値" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;fontColor=#334155;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-analyzer" target="a-features" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-e3" value="tensor + mask（入力制御）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;fontColor=#334155;align=right;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-features" target="a-manager" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-e4" value="上位候補 + parameter" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;fontColor=#334155;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-manager" target="a-preview" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-e5" value="preview 特徴量" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#7e22ce;strokeWidth=2;fontColor=#7e22ce;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-preview" target="a-manager" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="2340" y="100" />
              <mxPoint x="1780" y="100" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a-e6" value="選択済み PlannerRequest" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;fontColor=#334155;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-preview" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="2300" y="570" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="a-e7" value="\(K\) 件の候補" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;fontColor=#334155;entryX=0.512;entryY=0.003;entryDx=0;entryDy=0;entryPerimeter=0;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-worker" target="a-batch" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-e8" value="順位 0（先頭候補）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=3;fontColor=#dc2626;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-batch" target="a-compat" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="2295" y="1240" />
              <mxPoint x="2295" y="1240" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a-e10" value="telemetry（計測値）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#64748b;strokeWidth=2;fontColor=#64748b;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-batch" target="a-artifacts" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-e11" value="戦術定義 + 探索予算" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#b7791f;strokeWidth=2;fontColor=#b7791f;entryX=0.001;entryY=0.702;entryDx=0;entryDy=0;entryPerimeter=0;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-registry" target="a-manager" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1560" y="350" as="targetPoint" />
