              <mxPoint x="1550" y="750" />
              <mxPoint x="1550" y="350" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a-e12" value="探索設定" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#b7791f;strokeWidth=2;fontColor=#b7791f;entryX=0.25;entryY=0;entryDx=0;entryDy=0;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-registry" target="a-worker" edge="1">
          <mxGeometry relative="1" as="geometry">
