        </mxCell>
        <mxCell id="a-e9" value="配置 action" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;fontColor=#334155;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="WD4-vwN35DC2D8uVpPbx-1" target="a-action" edge="1">
