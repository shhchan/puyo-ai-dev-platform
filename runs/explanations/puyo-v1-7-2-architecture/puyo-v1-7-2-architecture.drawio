      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v172-decision-process" name="2. 観測可能な意思決定プロセス">
    <mxGraphModel dx="2313" dy="1321" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="1" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="6AE9F17jzYQiLMyGNvM--1" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="40" y="20" width="2335.73" height="1480" as="geometry" />
        </mxCell>
        <mxCell id="t-key" value="重要な区別&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;現在学習済み：戦術選択、戦術 parameter、preview を加味した裁定。&lt;br&gt;現在未学習：選択した Worker 内にある \(K\) 件の計画の順位付け。&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e5;strokeColor=#d97706;strokeWidth=3;fontColor=#7c2d12;fontSize=15;fontStyle=1;spacing=12;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="742.935" y="1140.0000000000002" width="831.36" height="114.31" as="geometry" />
        </mxCell>
        <mxCell id="t-4" value="4. 上位 3 戦術を preview&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;各戦術で予算制限付き Worker を実行&lt;br&gt;連鎖 / 攻撃 / 危険度を予測&lt;br&gt;期限と目標達成を確認&lt;br&gt;latency + 展開 node 数を記録&lt;br&gt;戦術 preview 特徴量を生成&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7e6;strokeColor=#b7791f;strokeWidth=2;fontColor=#623b00;fontSize=14;fontStyle=1;spacing=10;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="1345" y="218" width="287.21" height="206.59" as="geometry" />
        </mxCell>
        <mxCell id="t-title" value="観測可能な思考プロセス — 1 回の意思決定でモデルが計算する内容" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=25;fontStyle=1;fontColor=#172033;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="413.83804804804805" width="1599.2385585585587" height="70.14218009478672" as="geometry" />
        </mxCell>
        <mxCell id="t-note" value="ここで示すのは観測可能な処理経路と診断値であり、非公開の chain-of-thought（内部推論文）ではありません。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#94a3b8;fontColor=#475569;fontSize=13;fontStyle=2;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="708.4346246246247" y="84.17061611374407" width="1010.0454054054055" height="63.127962085308056" as="geometry" />
        </mxCell>
        <mxCell id="t-1" value="1. 局面を解析&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;何を構築 / 発火できるか？&lt;br&gt;双方の盤面はどれほど危険か？&lt;br&gt;どの攻撃がいつ到着するか？&lt;br&gt;相殺または返送できるか？&lt;br&gt;全消し bonus は消費済みか？&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf2ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#193763;fontSize=14;fontStyle=1;spacing=10;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="95" y="218" width="287.21" height="206.59" as="geometry" />
        </mxCell>
        <mxCell id="t-2" value="2. 強制的な適用条件を反映&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;Registry の candidate_when 規則を評価&lt;br&gt;不適用な戦術を mask&lt;br&gt;&lt;br&gt;予告おじゃま量 &amp;gt; 0の場合：&lt;br&gt;相殺可能なら counter_or_return を強制&lt;br&gt;それ以外は survive を強制&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;strokeWidth=2;fontColor=#7f1d1d;fontSize=14;fontStyle=1;spacing=10;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="483.98" y="218" width="287.21" height="206.59" as="geometry" />
        </mxCell>
        <mxCell id="t-3" value="3. 戦術を軽量評価&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;共有 context encoder（局面特徴抽出器）&lt;br&gt;戦術別の隠れ head&lt;br&gt;提案 logit / 価値 / リスク&lt;br&gt;目標制約を復号&lt;br&gt;beam 探索 parameter を復号&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7e22ce;strokeWidth=3;fontColor=#442260;fontSize=14;fontStyle=1;spacing=10;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="935" y="218" width="287.21" height="206.59" as="geometry" />
        </mxCell>
        <mxCell id="t-5" value="5. 最終戦術を裁定&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;戦術の隠れ状態&lt;br&gt;+ logit / 価値 / リスク&lt;br&gt;+ preview 特徴ベクトルを結合&lt;br&gt;&lt;br&gt;戦術を決定論的に 1 つ選択&lt;br&gt;（または response guard が上書き）&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7e22ce;strokeWidth=3;fontColor=#442260;fontSize=14;fontStyle=1;spacing=10;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="1985" y="213" width="301.11" height="216.59" as="geometry" />
        </mxCell>
        <mxCell id="t-6" value="6. PlannerRequest（探索依頼）を生成&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;戦術目標 + 閾値&lt;br&gt;目標連鎖 / 攻撃 / 期限&lt;br&gt;危険許容度 / 発火 policy&lt;br&gt;depth / width / 候補数 \(K\)&lt;br&gt;fallback 戦術&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7e6;strokeColor=#b7791f;strokeWidth=2;fontColor=#623b00;fontSize=14;fontStyle=1;spacing=10;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="1985" y="610.24" width="306.58" height="209.76" as="geometry" />
        </mxCell>
        <mxCell id="t-7" value="7. 選択した Worker 内を探索&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;構築：多様性を保つ beam 探索&lt;br&gt;対応：readiness Worker&lt;br&gt;その他：tactical Worker&lt;br&gt;&lt;br&gt;BuildPotential / 発火 / 危険度を評価&lt;br&gt;多様な初手 / 計画を保持&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#feecef;strokeColor=#be123c;strokeWidth=2;fontColor=#67142b;fontSize=14;fontStyle=1;spacing=10;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="1515" y="610.24" width="306.58" height="209.76" as="geometry" />
        </mxCell>
        <mxCell id="t-8" value="8. \(K\) 件の候補を固定形式へ正規化&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;初手 / 計画の重複を除去&lt;br&gt;合法手 mask を検証&lt;br&gt;安定 ID + padding mask&lt;br&gt;順位付け用 13 特徴量を直列化&lt;br&gt;coverage / regret の計測値&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#0891b2;strokeWidth=3;fontColor=#164e63;fontSize=14;fontStyle=1;spacing=10;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="1005.325" y="610.24" width="306.58" height="209.76" as="geometry" />
        </mxCell>
        <mxCell id="t-9" value="9. 現行の候補選択&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;compatibility mode が slot 0 を選択&lt;br&gt;Worker の heuristic 順がそのまま最終順位&lt;br&gt;&lt;br&gt;\(K\) 候補間の比較はまだ未学習&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;strokeWidth=3;fontColor=#7f1d1d;fontSize=14;fontStyle=1;spacing=10;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="483.98" y="610.24" width="306.58" height="209.76" as="geometry" />
        </mxCell>
        <mxCell id="t-10" value="10. 実行して結果を観測&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;配置を Simulator へ適用&lt;br&gt;連鎖 / 攻撃結果を確定&lt;br&gt;予告おじゃまと状態遷移を更新&lt;br&gt;戦術 / 提案 / 計画 / latency を保存&lt;br&gt;次の意思決定で繰り返す&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;fontColor=#14532d;fontSize=14;fontStyle=1;spacing=10;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="95" y="615.24" width="291.96" height="199.76" as="geometry" />
        </mxCell>
        <mxCell id="t-future" value="PUYO-130 では手順 9 を学習型の候補順位付けへ置換&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;CandidateRankerInput（固定形状の順位付け入力）→ mask 済み logit → 候補分布 → 選択 action&lt;br&gt;混合対戦相手に対する critic + 報酬 + entropy 更新&lt;br&gt;&lt;br&gt;探索が候補を生成し続け、RL がどの候補を選ぶかを学習する。&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#16a34a;strokeWidth=3;fontColor=#14532d;fontSize=15;fontStyle=1;spacing=12;dashed=1;" parent="6AE9F17jzYQiLMyGNvM--1" vertex="1">
          <mxGeometry x="735" y="919.9999999999999" width="847.23" height="195.92" as="geometry" />
        </mxCell>
        <mxCell id="t-e1" value="診断値" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-1" target="t-2" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t-e2" value="mask 済み特徴量" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-2" target="t-3" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t-e3" value="上位 logit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-3" target="t-4" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t-e4" value="preview tensor（事前探索結果）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#7e22ce;strokeWidth=2;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-4" target="t-5" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t-e5" value="選択戦術" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-5" target="t-6" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t-e6" value="探索依頼" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-6" target="t-7" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t-e7" value="未整形の候補" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-7" target="t-8" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t-e8" value="slot 0（先頭候補）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#dc2626;strokeWidth=3;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-8" target="t-9" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t-e9" value="配置" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#334155;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-9" target="t-10" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t-e10" value="次の局面" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#64748b;strokeWidth=2;dashed=1;entryX=0.5;entryY=1;entryDx=0;entryDy=0;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-10" target="t-1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="239" y="610" />
              <mxPoint x="239" y="410" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="t-e11" value="将来の候補 logit" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=3;dashed=1;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-8" target="t-future" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="t-e12" value="将来の選択候補" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=3;dashed=1;" parent="6AE9F17jzYQiLMyGNvM--1" source="t-future" target="t-10" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v172-gate-blocker" name="3. PUYO-130が開始不可となった理由">
    <mxGraphModel dx="1597" dy="912" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="1" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ik1cYBR1Yb5JweXHlFDj-1" value="" style="group" vertex="1" connectable="0" parent="1">
          <mxGeometry x="35" y="20" width="1730" height="1020" as="geometry" />
        </mxCell>
        <mxCell id="g-title" value="PUYO-170 学習前 Capability Gate — PUYO-130 long-run が BLOCKED となった理由" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=25;fontStyle=1;fontColor=#172033;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry x="215" width="1300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="g-config" value="Canonical input（標準評価条件）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;30 seed × 40 手、決定論的に 2 回反復&lt;br&gt;current（現行探索）：depth 3 / width 24 / probe 8 / \(K\) 8&lt;br&gt;reference（高予算の診断探索）：depth 8 / width 64 / probe 32&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;strokeWidth=2;fontColor=#334155;fontSize=14;fontStyle=1;spacing=10;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry x="415" y="65" width="900" height="100" as="geometry" />
        </mxCell>
        <mxCell id="g-suite" value="FAIL — 固定 suite（共通評価セット）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;要件：30/30 game が 40 手へ到達&lt;br&gt;実績：29/30&lt;br&gt;seed 146 は意思決定 39 で終了&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;strokeWidth=3;fontColor=#7f1d1d;fontSize=14;fontStyle=1;spacing=10;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry y="215" width="315" height="160" as="geometry" />
        </mxCell>
        <mxCell id="g-chain" value="FAIL — 大連鎖の生成能力&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;要件：最大連鎖数の平均 ≥ 10&lt;br&gt;実績：2.933&lt;br&gt;分布：0〜11、11 連鎖は 1 seedのみ&lt;br&gt;\(K\) 候補内の最良値平均：2.933&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;strokeWidth=3;fontColor=#7f1d1d;fontSize=14;fontStyle=1;spacing=10;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry x="350" y="205" width="330" height="180" as="geometry" />
        </mxCell>
        <mxCell id="g-gap" value="PASS — 直近の安全性 gap&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;回避可能な未発火 gap：0&lt;br&gt;強制 game-over gap：0&lt;br&gt;&lt;br&gt;ただし長期的な構築品質の証明ではない。&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;fontColor=#14532d;fontSize=14;fontStyle=1;spacing=10;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry x="1085" y="215" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="g-latency" value="FAIL — Registry の latency 予算&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;要件：提案生成 p95 ≤ 60 ms&lt;br&gt;実績 p50 / p95：582.67 / 917.12 ms&lt;br&gt;計測：実時間の観測値&lt;br&gt;提案データへの変換時間を含む&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;strokeWidth=3;fontColor=#7f1d1d;fontSize=14;fontStyle=1;spacing=10;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry x="725" y="205" width="330" height="180" as="geometry" />
        </mxCell>
        <mxCell id="g-determinism" value="PASS — 再現性&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;2 回の反復で同一 digest&lt;br&gt;c0c076…c783 × 2&lt;br&gt;&lt;br&gt;失敗結果も決定論的に再現する。&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;fontColor=#14532d;fontSize=14;fontStyle=1;spacing=10;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry x="1415" y="215" width="315" height="160" as="geometry" />
        </mxCell>
        <mxCell id="g-coverage" value="Coverage（探索網羅率）の根拠&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;reference の最良連鎖平均：6.600&lt;br&gt;reference 初手の coverage：83.7%&lt;br&gt;reference 経路の coverage：65.1%&lt;br&gt;候補不足に起因する早すぎる発火：27 件&lt;br&gt;&lt;br&gt;高予算 reference は改善するが 10 未満。&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf2ff;strokeColor=#2563eb;strokeWidth=2;fontColor=#193763;fontSize=14;fontStyle=1;spacing=10;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry x="115" y="470" width="430" height="220" as="geometry" />
        </mxCell>
        <mxCell id="g-diagnosis" value="原因診断&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;1. 現行 \(K\) 候補 / 経路では、複数 seed で安定する 10 連鎖以上の継続手を提示できない。&lt;br&gt;2. reference の初手 / 経路 prefix 欠落は、探索深さ・枝刈り・候補 coverage の損失を示す。&lt;br&gt;3. 探索 + 提案データ変換は p95 で Runtime 予算の約 15 倍。&lt;br&gt;4. 1 経路は依然として早期 game-over に至る。&lt;br&gt;&lt;br&gt;つまり、良い候補群から学習器が誤選択しただけではない。&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e5;strokeColor=#d97706;strokeWidth=3;fontColor=#7c2d12;fontSize=15;fontStyle=1;spacing=12;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry x="665" y="445" width="650" height="270" as="geometry" />
        </mxCell>
        <mxCell id="g-not" value="Blocker ではなかったもの&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;PUYO-158 の脅威 scenario：6/6 PASS&lt;br&gt;回避可能な候補 gap：0&lt;br&gt;強制 game-over 候補 gap：0&lt;br&gt;schema / hash / 決定性：PASS&lt;br&gt;&lt;br&gt;脅威対応は機能する一方、安全な長連鎖構築が不足。&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#0891b2;strokeWidth=2;fontColor=#164e63;fontSize=14;fontStyle=1;spacing=10;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry x="1355" y="470" width="375" height="220" as="geometry" />
        </mxCell>
        <mxCell id="g-why" value="long-run 学習前に停止する理由&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;学習型 Ranker は候補の順序を変えられるが、欠けた長期計画は生成できない。&lt;br&gt;不十分 / 予算超過の action 集合で学習すると、早すぎる発火や脆い構築を残したまま対戦勝率だけを最適化し得る。&lt;br&gt;Gate は RL が候補生成器の欠陥を覆い隠すことと、無効な action 空間への計算資源投入を防ぐ。&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#7e22ce;strokeWidth=3;fontColor=#442260;fontSize=15;fontStyle=1;spacing=12;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
          <mxGeometry x="195" y="790" width="760" height="230" as="geometry" />
        </mxCell>
        <mxCell id="g-block" value="判定：PUYO-130 LONG-RUN = BLOCKED（開始不可）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;Registry 予算内の単一設定で全 Capability Gate を通過した場合のみ解除：&lt;br&gt;30/30 × 40 手、最大連鎖平均 ≥ 10、安全性 gap 0、p95 ≤ 60 ms、決定論的反復一致。&lt;br&gt;&lt;br&gt;その後 PUYO-130 で CandidateRanker / critic を学習可能。PUYO-133 で学習後の選択 policy を別途評価する。&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7f1d1d;strokeColor=#450a0a;strokeWidth=4;fontColor=#ffffff;fontSize=16;fontStyle=1;spacing=14;" parent="ik1cYBR1Yb5JweXHlFDj-1" vertex="1">
