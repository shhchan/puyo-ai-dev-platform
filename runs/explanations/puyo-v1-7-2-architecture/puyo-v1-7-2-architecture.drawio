            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a-e13" value="候補特徴量" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=3;dashed=1;fontColor=#16a34a;entryX=0.5;entryY=0;entryDx=0;entryDy=0;exitX=0.299;exitY=0.998;exitDx=0;exitDy=0;exitPerimeter=0;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-batch" target="a-future" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-e15" value="schema 検証済み重み" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#d97706;strokeWidth=2;fontColor=#d97706;entryX=-0.002;entryY=0.601;entryDx=0;entryDy=0;entryPerimeter=0;" parent="tKkHR2rGfIARAxmE2a8m-1" source="a-checkpoint" target="a-manager" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a-action" value="9. 配置実行 + Simulator（公式状態更新器）&lt;br&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;br&gt;合法な action を1つ実行&lt;br&gt;連鎖 / 攻撃 / 状態遷移を確定&lt;br&gt;診断値を replay / rollout へ保存&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;fontColor=#14532d;fontSize=14;fontStyle=1;spacing=10;" parent="WD4-vwN35DC2D8uVpPbx-1" vertex="1">
          <mxGeometry x="2140" y="1690" width="330" height="160" as="geometry" />
        </mxCell>
        <mxCell id="a-e14" value="学習による選択（PUYO-130 後）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#16a34a;strokeWidth=3;dashed=1;fontColor=#16a34a;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.349;entryY=-0.011;entryDx=0;entryDy=0;entryPerimeter=0;" parent="WD4-vwN35DC2D8uVpPbx-1" source="a-future" target="a-action" edge="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1830" y="1630" />
