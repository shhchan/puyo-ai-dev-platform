{
  "schema_version": "puyo.state_analyzer.scenarios.v1",
  "scenarios": [
    {
      "name": "short_tactical_sub_chain_keeps_main_distinct",
      "category": "short_tactical_attack",
      "situation": "A two-chain attack is available now while the larger three-chain main line needs the visible NEXT.",
      "expected_behavior": ["Report the one-turn two-chain as a sub-chain.", "Keep the two-turn three-chain as the main chain."],
      "non_goals": ["Do not choose whether the manager should fire the sub-chain."],
      "own": {"board": ["RGGYGG", "BGRRGR", "..RGYB", "..BR.G", "..R...", "......", "......", "......", "......", "......", "......", "......", "......", "......"], "current_pair": "RR", "next_pairs": ["RG", "RB"]},
      "opponent": {"board": ["......", "......", "......", "......", "......", "......", "......", "......", "......", "......", "......", "......", "......", "......"], "current_pair": "GY", "next_pairs": ["RB", "YP"]},
      "expectations": [
        {"path": "own.forecast.immediate_attack", "op": "eq", "value": 6},
        {"path": "own.forecast.main_chain.turns", "op": "eq", "value": 2},
        {"path": "own.forecast.main_chain.chain_count", "op": "eq", "value": 3},
        {"path": "own.attack_options", "op": "any_match", "value": {"turns": 1, "chain_count": 2, "is_main_chain": false, "is_sub_chain": true}}
      ]
    },
    {
      "name": "immediate_rush_is_not_sub_chain",
      "category": "rush",
      "situation": "The current pair immediately fires the best two-chain attack from a shallow rush shape.",
      "expected_behavior": ["Report a one-turn immediate attack.", "Do not relabel equivalent rush routes as sub-chains."],
      "non_goals": ["Do not judge whether rushing is strategically correct."],
      "own": {"board": ["RRRBBB", "......", "......", "......", "......", "......", "......", "......", "......", "......", "......", "......", "......", "......"], "current_pair": "RB", "next_pairs": ["GY", "BR"]},
