        {"path": "own.forecast.immediate_attack", "op": "eq", "value": 5},
        {"path": "own.forecast.main_chain.turns", "op": "eq", "value": 1},
        {"path": "own.attack_options", "op": "none_match", "value": {"is_sub_chain": true}}
      ]
    },
